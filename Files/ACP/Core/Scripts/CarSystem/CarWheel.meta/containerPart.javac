      vw.setFrictionSlip(runningFriction * startFriction); //[I-S]LN=96;[I-E]
    } //[I-S]LN=97;[I-E]
 //[I-S]LN=98;[I-E]
    float blockRotI = activeHBrake + activeBrake; //[I-S]LN=99;[I-E]
