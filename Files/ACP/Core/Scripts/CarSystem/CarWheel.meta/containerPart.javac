    vw.setBlockRotation(blockRotI); //[I-S]LN=101;[I-E]
 //[I-S]LN=102;[I-E]
    calculatePivot(); //[I-S]LN=103;[I-E]
    updateSmokeDir(); //[I-S]LN=104;[I-E]
