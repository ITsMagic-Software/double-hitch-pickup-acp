 //[I-S]LN=106;[I-E]
  private Vector3 calculateBottomWheelLocalPos() { //[I-S]LN=107;[I-E]
Vector3 p = myObject.getPosition().copy(); //[I-S]LN=108;[I-E]
      float y = p.getY(); //[I-S]LN=109;[I-E]
y -= vw.getRadius(); //[I-S]LN=110;[I-E]
      p.setY(y); //[I-S]LN=111;[I-E]
      return p; //[I-S]LN=112;[I-E]
  }  //[I-S]LN=113;[I-E]
 //[I-S]LN=114;[I-E]
  private Vector3 calculateSteerVector() { //[I-S]LN=115;[I-E]
    Vector3 up = myObject.up(); //[I-S]LN=116;[I-E]
    Vector3 right = myObject.getChildAt(0).right(); //[I-S]LN=117;[I-E]
    Vector3 dir = up.cross(right); //[I-S]LN=118;[I-E]
    return dir; //[I-S]LN=119;[I-E]
  } //[I-S]LN=120;[I-E]
 //[I-S]LN=121;[I-E]
  private void updateSmokeDir() { //[I-S]LN=122;[I-E]
    Vector3 dir = calculateSteerVector(); //[I-S]LN=123;[I-E]
    Quaternion rot = new Quaternion(); //[I-S]LN=124;[I-E]
    rot.lookTo(dir); //[I-S]LN=125;[I-E]
    smokePO.setGlobalRotation(rot); //[I-S]LN=126;[I-E]
     //[I-S]LN=127;[I-E]
    Vector3 p = calculateBottomWheelLocalPos(); //[I-S]LN=128;[I-E]
    p.setY(p.getY() + 0.01f); //[I-S]LN=129;[I-E]
    smokePO.setPosition(p); //[I-S]LN=130;[I-E]
  } //[I-S]LN=131;[I-E]
 //[I-S]LN=132;[I-E]
  private void calculatePivot() { //[I-S]LN=133;[I-E]
SpatialObject car = myObject.getMainParent(); //[I-S]LN=134;[I-E]
Vector3 myPos = myObject.getGlobalPosition(); //[I-S]LN=135;[I-E]
    Vector3 pivot = car.inverseTransformPoint(myPos); //[I-S]LN=136;[I-E]
horizontalPivot = pivot.getX(); //[I-S]LN=137;[I-E]
  } //[I-S]LN=138;[I-E]
