 //[I-S]LN=5;[I-E]
  @Order(idx = {2}) //[I-S]LN=6;[I-E]
  public boolean brake = true; //[I-S]LN=7;[I-E]
 //[I-S]LN=8;[I-E]
  @Order(idx = {3}) //[I-S]LN=9;[I-E]
  public boolean steer = false; //[I-S]LN=10;[I-E]
 //[I-S]LN=11;[I-E]
  @Order(idx = {4}) //[I-S]LN=12;[I-E]
  public boolean handBrake = true; //[I-S]LN=13;[I-E]
 //[I-S]LN=14;[I-E]
