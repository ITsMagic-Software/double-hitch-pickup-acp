 //[I-S]LN=159;[I-E]
  public ICarMotor findMotor() { //[I-S]LN=160;[I-E]
    ICarMotor c = (ICarMotor) myObject.findComponentInParent(ICarMotor.class); //[I-S]LN=161;[I-E]
    if (c == null) { //[I-S]LN=162;[I-E]
        throw new NullPointerException("no motor found"); //[I-S]LN=163;[I-E]
    }  //[I-S]LN=164;[I-E]
    return c; //[I-S]LN=165;[I-E]
  } //[I-S]LN=166;[I-E]
 //[I-S]LN=167;[I-E]
  /* override */ //[I-S]LN=168;[I-E]
  public float getHorizontalPivot() { //[I-S]LN=169;[I-E]
    return horizontalPivot; //[I-S]LN=170;[I-E]
  } //[I-S]LN=171;[I-E]
} //[I-S]LN=172;[I-E]
