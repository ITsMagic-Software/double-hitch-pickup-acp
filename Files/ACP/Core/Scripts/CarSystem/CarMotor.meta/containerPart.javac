//C-R:CarCamera
class CarCamera extends Component {
   /* @Author ITsMagic */ //[I-S]LN=0;[I-E]
    //[I-S]LN=1;[I-E]
   @AutoWired private SmoothCameraFollow scf; //[I-S]LN=2;[I-E]
    //[I-S]LN=3;[I-E]
   /// Run only once //[I-S]LN=4;[I-E]
public    void start() {} //[I-S]LN=5;[I-E]
    //[I-S]LN=6;[I-E]
   /// Repeat every frame //[I-S]LN=7;[I-E]
public    void repeat() { //[I-S]LN=8;[I-E]
     SpatialObject target = scf.getTarget(); //[I-S]LN=9;[I-E]
     if (target != null) { //[I-S]LN=10;[I-E]
if (!target.isEnabled()) { //[I-S]LN=11;[I-E]
         target = null; //[I-S]LN=12;[I-E]
       } else { //[I-S]LN=13;[I-E]
         CarMotor cm = target.findComponent(CarMotor.class); //[I-S]LN=14;[I-E]
         if (cm == null || !cm.engineOn) { //[I-S]LN=15;[I-E]
           target = null; //[I-S]LN=16;[I-E]
         } //[I-S]LN=17;[I-E]
       } //[I-S]LN=18;[I-E]
     } //[I-S]LN=19;[I-E]
    //[I-S]LN=20;[I-E]
     // find a new car to attach to smooth camera follower //[I-S]LN=21;[I-E]
     if (target == null) { //[I-S]LN=22;[I-E]
       List<Component> cms = WorldController.listAllComponents(CarMotor.class); //[I-S]LN=23;[I-E]
       for (int x = 0; x < cms.size(); x++) { //[I-S]LN=24;[I-E]
         CarMotor cm = (CarMotor) cms.get(x); //[I-S]LN=25;[I-E]
         if (cm.engineOn) { //[I-S]LN=26;[I-E]
           target = cm.myObject; //[I-S]LN=27;[I-E]
           CarCameraSettings ccs = target.findComponent(CarCameraSettings.class); //[I-S]LN=28;[I-E]
           if (ccs != null) { //[I-S]LN=29;[I-E]
             scf.setDistance(ccs.distance); //[I-S]LN=30;[I-E]
             scf.setHeight(ccs.height); //[I-S]LN=31;[I-E]
           }  //[I-S]LN=32;[I-E]
           scf.setTarget(target); //[I-S]LN=33;[I-E]
           break; //[I-S]LN=34;[I-E]
         } //[I-S]LN=35;[I-E]
       } //[I-S]LN=36;[I-E]
     } //[I-S]LN=37;[I-E]
   } //[I-S]LN=38;[I-E]
}
