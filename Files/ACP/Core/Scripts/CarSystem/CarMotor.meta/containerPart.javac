 //[I-S]LN=34;[I-E]
  private float activeBrake; //[I-S]LN=35;[I-E]
  private float activeHBrake; //[I-S]LN=36;[I-E]
  private float activeTorque; //[I-S]LN=37;[I-E]
 //[I-S]LN=38;[I-E]
  private float wantedSkid = 0; //[I-S]LN=39;[I-E]
 //[I-S]LN=40;[I-E]
  private float startFriction; //[I-S]LN=41;[I-E]
  private float emitThrrotleParticleTime = 0; //[I-S]LN=42;[I-E]
 //[I-S]LN=43;[I-E]
  private float horizontalPivot; //[I-S]LN=44;[I-E]
 //[I-S]LN=45;[I-E]
  /// Run only once //[I-S]LN=46;[I-E]
  @Override //[I-S]LN=47;[I-E]
  public void start() { //[I-S]LN=48;[I-E]
    motor = findMotor(); //[I-S]LN=49;[I-E]
    startFriction = vw.getFrictionSlip(); //[I-S]LN=50;[I-E]
  } //[I-S]LN=51;[I-E]
 //[I-S]LN=52;[I-E]
  /// Repeat every frame //[I-S]LN=53;[I-E]
  @Override //[I-S]LN=54;[I-E]
  public void repeat() { //[I-S]LN=55;[I-E]
    if (motor != null) { //[I-S]LN=56;[I-E]
      motor.addWheel(this); //[I-S]LN=57;[I-E]
    } //[I-S]LN=58;[I-E]
 //[I-S]LN=59;[I-E]
    if (throttleParticle != null) { //[I-S]LN=60;[I-E]
      if (emitThrrotleParticleTime > 0) { //[I-S]LN=61;[I-E]
        emitThrrotleParticleTime -= Math.bySecond(); //[I-S]LN=62;[I-E]
        throttleParticle.setAllowEmission(true); //[I-S]LN=63;[I-E]
        wantedSkid += 0.5f; //[I-S]LN=64;[I-E]
      } else { //[I-S]LN=65;[I-E]
        throttleParticle.setAllowEmission(false); //[I-S]LN=66;[I-E]
      } //[I-S]LN=67;[I-E]
    } //[I-S]LN=68;[I-E]
 //[I-S]LN=69;[I-E]
    if (wsk != null && wantedSkid > 0) { //[I-S]LN=70;[I-E]
      wsk.emit(wantedSkid); //[I-S]LN=71;[I-E]
      wantedSkid -= Math.bySecond(5f); //[I-S]LN=72;[I-E]
    } //[I-S]LN=73;[I-E]
    wantedSkid = Math.clamp(0, wantedSkid, 1); //[I-S]LN=74;[I-E]
 //[I-S]LN=75;[I-E]
    if (activeHBrake > 0) { //[I-S]LN=76;[I-E]
      vw.setFrictionSlip(handBrakingFriction * startFriction); //[I-S]LN=77;[I-E]
    } else { //[I-S]LN=78;[I-E]
      vw.setFrictionSlip(runningFriction * startFriction); //[I-S]LN=79;[I-E]
    } //[I-S]LN=80;[I-E]
 //[I-S]LN=81;[I-E]
    float blockRotI = activeHBrake + activeBrake; //[I-S]LN=82;[I-E]
    blockRotI = Math.clamp(0, blockRotI, 1); //[I-S]LN=83;[I-E]
    vw.setBlockRotation(blockRotI); //[I-S]LN=84;[I-E]
 //[I-S]LN=85;[I-E]
    calculatePivot(); //[I-S]LN=86;[I-E]
  } //[I-S]LN=87;[I-E]
 //[I-S]LN=88;[I-E]
  private void calculatePivot() { //[I-S]LN=89;[I-E]
SpatialObject car = myObject.getMainParent(); //[I-S]LN=90;[I-E]
Vector3 myPos = myObject.getGlobalPosition(); //[I-S]LN=91;[I-E]
    Vector3 pivot = car.inverseTransformPoint(myPos); //[I-S]LN=92;[I-E]
horizontalPivot = pivot.getX(); //[I-S]LN=93;[I-E]
  } //[I-S]LN=94;[I-E]
 //[I-S]LN=95;[I-E]
  /* override */ //[I-S]LN=96;[I-E]
  public void setTorque(float v) { //[I-S]LN=97;[I-E]
    if (torque) { //[I-S]LN=98;[I-E]
      v = v * (1 - activeHBrake); //[I-S]LN=99;[I-E]
      activeTorque = v; //[I-S]LN=100;[I-E]
      vw.setTorque(v); //[I-S]LN=101;[I-E]
    } //[I-S]LN=102;[I-E]
  } //[I-S]LN=103;[I-E]
 //[I-S]LN=104;[I-E]
  /* override */ //[I-S]LN=105;[I-E]
  public void setBrake(float v) { //[I-S]LN=106;[I-E]
    if (brake) { //[I-S]LN=107;[I-E]
      activeBrake = v; //[I-S]LN=108;[I-E]
      v = v + activeHBrake; //[I-S]LN=109;[I-E]
