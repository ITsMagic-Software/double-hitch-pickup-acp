       //[I-S]LN=7;[I-E]
  }  //[I-S]LN=8;[I-E]
 //[I-S]LN=9;[I-E]
  public CSKeyH(String name) { //[I-S]LN=10;[I-E]
    this.name = name; //[I-S]LN=11;[I-E]
  } //[I-S]LN=12;[I-E]
 //[I-S]LN=13;[I-E]
  public Key get() { //[I-S]LN=14;[I-E]
