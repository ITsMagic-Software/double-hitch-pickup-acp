  } //[I-S]LN=140;[I-E]
 //[I-S]LN=141;[I-E]
  /* override */ //[I-S]LN=142;[I-E]
  public void emitThrottleParticle(float i, boolean forward) { //[I-S]LN=143;[I-E]
    if (torque) { //[I-S]LN=144;[I-E]
      emitThrrotleParticleTime = 0.5f; //[I-S]LN=145;[I-E]
      if (invertSimulatedRotation) forward = !forward; //[I-S]LN=146;[I-E]
      if (forward) { //[I-S]LN=147;[I-E]
        vw.incrementRotation(Math.bySecond(15 * i)); //[I-S]LN=148;[I-E]
      } else { //[I-S]LN=149;[I-E]
        vw.incrementRotation(Math.bySecond(-15 * i)); //[I-S]LN=150;[I-E]
